# Copy to %AppData%\Sentimentanalys\user_config.yaml (or user_data/ in portable mode)
version: 1
install_profile: cli
sentiment_profile: callcenter
device: auto
portable_mode: false
log_level: INFO

paths:
  app_root: ""
  hf_cache: cache/hf
  llm_cache: cache/llm
  outputs: outputs
  incoming_calls: ""

asr:
  backend: faster
  model: kb-whisper-large
  revision: strict
  language: sv
  preprocess: false

llm:
  enabled: false
  default_model: mistralai/mistral-medium-3.5
  cost_budget_per_call: 0.08
  anonymize_before_llm: false

services:
  api_host: 127.0.0.1
  api_port: 8000
  dashboard_port: 8501